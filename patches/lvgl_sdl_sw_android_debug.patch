 static inline int sdl_render_mode(void)
 {
+#ifdef __ANDROID__
+    /* FULL mode redraws the entire screen when anything is dirty, avoiding stale
+     * framebuffer artifacts from DIRECT mode's partial dirty-region tracking.
+     * Performance impact is minimal: LVGL still skips rendering when nothing
+     * changes, and a full-screen redraw is cheap on mobile GPUs. */
+    return LV_DISPLAY_RENDER_MODE_FULL;
+#else
     return LV_SDL_RENDER_MODE;
+#endif
