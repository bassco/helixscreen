     #include <malloc.h>
 #endif /* _WIN32 */
 
+#ifdef __ANDROID__
+    #include <android/log.h>
+    #define ALOGD(...) __android_log_print(ANDROID_LOG_DEBUG, "HelixSDL_SW", __VA_ARGS__)
+#else
+    #define ALOGD(...) (void)0
+#endif
+
 #include "../../display/lv_display_private.h"
 #include "../../misc/lv_types.h"
 #include "../../draw/sw/lv_draw_sw_utils.h"
@@ -58,7 +65,15 @@ static lv_result_t window_update(lv_display_t * disp);
 
 static inline int sdl_render_mode(void)
 {
+#ifdef __ANDROID__
+    /* FULL mode redraws the entire screen when anything is dirty, avoiding stale
+     * framebuffer artifacts from DIRECT mode's partial dirty-region tracking.
+     * Performance impact is minimal: LVGL still skips rendering when nothing
+     * changes, and a full-screen redraw is cheap on mobile GPUs. */
+    return LV_DISPLAY_RENDER_MODE_FULL;
+#else
     return LV_SDL_RENDER_MODE;
+#endif
 }
 
 static lv_result_t init_display(lv_display_t * display);
@@ -176,7 +191,15 @@ static lv_result_t resize_display(lv_display_t * display)
 
     ddata->texture = SDL_CreateTexture(ddata->renderer, px_format,
                                        SDL_TEXTUREACCESS_STATIC, display->hor_res, display->ver_res);
-    SDL_SetTextureBlendMode(ddata->texture, SDL_BLENDMODE_BLEND);
+    ALOGD("resize_display: texture=%dx%d fb1=%p fb2=%p stride=%u",
+          (int)display->hor_res, (int)display->ver_res,
+          (void*)ddata->fb1, (void*)ddata->fb2, (unsigned)stride);
+    /* BLENDMODE_NONE — the framebuffer texture covers the full viewport and doesn't
+     * need alpha blending. On Android GLES, SDL may promote RGB888 to GL_RGBA
+     * internally, turning the XRGB padding byte into alpha. With BLENDMODE_BLEND,
+     * pixels where LVGL left the padding byte as 0 become transparent, showing
+     * stale renderer content through. */
+    SDL_SetTextureBlendMode(ddata->texture, SDL_BLENDMODE_NONE);
     return LV_RESULT_OK;
 }
 
