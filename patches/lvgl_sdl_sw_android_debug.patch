+        ALOGD("window_update: disp=%dx%d tex=%dx%d stride=%u fb_act=%p",
+              (int)display->hor_res, (int)display->ver_res,
+              tex_w, tex_h, (unsigned)stride, (void*)ddata->fb_act);
+    }
     SDL_UpdateTexture(ddata->texture, NULL, ddata->fb_act, stride);
 
