diff --git a/src/core/lv_obj_event.c b/src/core/lv_obj_event.c
index 03fc68672..2b5dbabe7 100644
--- a/src/core/lv_obj_event.c
+++ b/src/core/lv_obj_event.c
@@ -59,7 +59,13 @@ lv_result_t lv_obj_send_event(lv_obj_t * obj, lv_event_code_t event_code, void *
 
     LV_ASSERT_OBJ(obj, MY_CLASS);
 
-    lv_event_t e;
+    /* HelixScreen: __cleanup__ pop fires on every scope exit including C++
+     * exception unwind. Without this, a throwing event callback would skip
+     * the explicit pop below, leaving event_head pointing at &e on a stack
+     * frame that's about to be destroyed. The next lv_event_mark_deleted
+     * call walks the dead pointer and SIGBUSes (#793/#840/#871/#878/#880,
+     * bundle RPHAV9T7). Idempotent — no-op when explicit pop already ran. */
+    lv_event_t e __attribute__((__cleanup__(lv_event_pop_if_head)));
     e.current_target = obj;
     e.original_target = obj;
     e.code = event_code;
diff --git a/src/misc/lv_event.c b/src/misc/lv_event.c
index 65e107258..33f9db243 100644
--- a/src/misc/lv_event.c
+++ b/src/misc/lv_event.c
@@ -88,11 +88,26 @@ void lv_event_pop(lv_event_t * e)
     event_head = e->prev;
 }
 
+/* HelixScreen: idempotent pop. Pops only if `e` is still the head of the
+ * chain. Used as the body of __cleanup__-attribute helpers in
+ * lv_obj_send_event and lv_event_push_and_send so a C++ exception unwinding
+ * through those C frames can't leave event_head pointing at a defunct stack
+ * frame (root cause of #793/#840/#871/#878/#880, bundle RPHAV9T7). */
+void lv_event_pop_if_head(lv_event_t * e)
+{
+    if(event_head == e) {
+        event_head = e->prev;
+    }
+}
+
 lv_result_t lv_event_push_and_send(lv_event_list_t * event_list, lv_event_code_t code, void * original_target,
                                    void * param)
 {
     LV_ASSERT_NULL(event_list);
-    lv_event_t e;
+    /* HelixScreen: __cleanup__ pop fires on scope exit including C++ exception
+     * unwind. Explicit lv_event_pop below still runs on the normal path; the
+     * cleanup is a no-op then because event_head no longer equals &e. */
+    lv_event_t e __attribute__((__cleanup__(lv_event_pop_if_head)));
     lv_memzero(&e, sizeof(e));
     e.code = code;
     e.current_target = original_target;
diff --git a/src/misc/lv_event_private.h b/src/misc/lv_event_private.h
index 92efc3e81..22ae88655 100644
--- a/src/misc/lv_event_private.h
+++ b/src/misc/lv_event_private.h
@@ -63,6 +63,15 @@ void lv_event_push(lv_event_t * e);
 
 void lv_event_pop(lv_event_t * e);
 
+/**
+ * HelixScreen: idempotent pop — only pops if `e` is still event_head.
+ * Safe to call from a __cleanup__ handler on both normal and exception
+ * unwind paths. Prevents `event_head` from being stranded on a defunct
+ * stack frame when a C++ exception unwinds through lv_event_push_and_send
+ * or lv_obj_send_event (root cause of #793/#840/#871/#878/#880).
+ */
+void lv_event_pop_if_head(lv_event_t * e);
+
 
 lv_result_t lv_event_push_and_send(lv_event_list_t * event_list, lv_event_code_t code, void * original_target,
                                    void * param);
