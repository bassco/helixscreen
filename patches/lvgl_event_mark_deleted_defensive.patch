diff --git a/src/misc/lv_event.c b/src/misc/lv_event.c
index 39c17ffd1..353f19834 100644
--- a/src/misc/lv_event.c
+++ b/src/misc/lv_event.c
@@ -12,6 +12,12 @@
 #include "lv_assert.h"
 #include "lv_types.h"

+#include <stdio.h>
+
+/* Telemetry hook provided by helix_lvgl_anomaly.cpp — reports LVGL anomalies
+ * to TelemetryManager with a hex backtrace. Weak so unit tests link without it. */
+extern void helix_lvgl_anomaly(const char * code, const char * context) __attribute__((weak));
+
 /*********************
  *      DEFINES
  *********************/
@@ -317,9 +323,45 @@ uint32_t lv_event_register_id(void)

 void lv_event_mark_deleted(void * target)
 {
+    /* HelixScreen: defensive bail on a corrupt event_head chain.
+     *
+     * Crash family #190 / #80 / #776 / #840 / #873-878 hit SIGSEGV/SIGBUS
+     * here when `event_head` (a stack-allocated chain pushed by lv_event_send
+     * and popped on return) somehow retained a stale pointer past its frame's
+     * unwind. The corrupted entry was reused by the heap, so dereferencing
+     * `e->original_target` faulted on garbage — most often the ASCII bytes of
+     * an unrelated string allocation.
+     *
+     * To convert these crashes into actionable telemetry without losing the
+     * widget context (the LV_OBJ being deleted), cap the chain walk at a
+     * sane depth and validate alignment at each step. On a runaway, log via
+     * helix_lvgl_anomaly (which captures a backtrace) and zero out event_head
+     * so subsequent dispatches get a clean slate. */
     lv_event_t * e = event_head;
+    unsigned depth = 0;
+    const unsigned max_depth = 256;            /* deepest plausible nested send chain */

     while(e) {
+        if(((uintptr_t)e & (sizeof(void *) - 1)) != 0u) {
+            if(helix_lvgl_anomaly) {
+                char ctx[96];
+                snprintf(ctx, sizeof(ctx), "head=%p target=%p depth=%u (misaligned)",
+                         (void *)e, target, depth);
+                helix_lvgl_anomaly("event_head_misaligned", ctx);
+            }
+            event_head = NULL;
+            return;
+        }
+        if(++depth > max_depth) {
+            if(helix_lvgl_anomaly) {
+                char ctx[96];
+                snprintf(ctx, sizeof(ctx), "head=%p target=%p (chain >%u)",
+                         (void *)event_head, target, max_depth);
+                helix_lvgl_anomaly("event_head_runaway", ctx);
+            }
+            event_head = NULL;
+            return;
+        }
         if(e->original_target == target || e->current_target == target) e->deleted = 1;
         e = e->prev;
     }
