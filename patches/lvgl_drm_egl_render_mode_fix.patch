Date: Thu, 5 Mar 2026 14:01:15 +0100
Subject: [PATCH] fix(drm/egl): correctly set render mode for nanovg (#9806)

---
 src/drivers/display/drm/lv_linux_drm_egl.c | 1 -
 1 file changed, 1 deletion(-)

diff --git a/src/drivers/display/drm/lv_linux_drm_egl.c b/src/drivers/display/drm/lv_linux_drm_egl.c
index 546256611..2e7d3f3ac 100644
--- a/src/drivers/display/drm/lv_linux_drm_egl.c
+++ b/src/drivers/display/drm/lv_linux_drm_egl.c
@@ -134,7 +134,6 @@ lv_result_t lv_linux_drm_set_file(lv_display_t * display, const char * file, int
     }
 
     lv_display_set_flush_cb(display, flush_cb);
-    lv_display_set_render_mode(display, LV_DISPLAY_RENDER_MODE_DIRECT);
     lv_display_set_render_mode(display, LV_USE_DRAW_NANOVG ? LV_DISPLAY_RENDER_MODE_FULL : LV_DISPLAY_RENDER_MODE_DIRECT);
 
     lv_display_add_event_cb(ctx->display, event_cb, LV_EVENT_RESOLUTION_CHANGED, NULL);
