From ec053a0d9458d204deca6f1d0b075e6e29979c48 Mon Sep 17 00:00:00 2001
From: Malte Nilges <malte.nilges@hotmail.de>
Date: Thu, 26 Feb 2026 13:34:42 +0100
Subject: [PATCH] fix(draw/gles/sdl): add null checks to texture cache
 comparison (#9770)

---
 src/draw/opengles/lv_draw_opengles.c | 6 ++++++
 src/draw/sdl/lv_draw_sdl.c           | 6 ++++++
 2 files changed, 12 insertions(+)

diff --git a/src/draw/opengles/lv_draw_opengles.c b/src/draw/opengles/lv_draw_opengles.c
index 97a3decc6..edadb79e8 100644
--- a/src/draw/opengles/lv_draw_opengles.c
+++ b/src/draw/opengles/lv_draw_opengles.c
@@ -163,6 +163,12 @@ static lv_cache_compare_res_t opengles_texture_cache_compare_cb(const cache_data
         return lhs->h > rhs->h ? 1 : -1;
     }
 
+    if(lhs->draw_dsc == NULL || rhs->draw_dsc == NULL) {
+        if(lhs->draw_dsc == rhs->draw_dsc) return 0;
+        if(lhs->draw_dsc == NULL) return -1;
+        return 1;
+    }
+
     uint32_t lhs_dsc_size = lhs->draw_dsc->dsc_size;
     uint32_t rhs_dsc_size = rhs->draw_dsc->dsc_size;
 
diff --git a/src/draw/sdl/lv_draw_sdl.c b/src/draw/sdl/lv_draw_sdl.c
index e3fe6b02c..c4f7469c6 100644
--- a/src/draw/sdl/lv_draw_sdl.c
+++ b/src/draw/sdl/lv_draw_sdl.c
@@ -92,6 +92,12 @@ static lv_cache_compare_res_t sdl_texture_cache_compare_cb(const cache_data_t *
         return lhs->h > rhs->h ? 1 : -1;
     }
 
+    if(lhs->draw_dsc == NULL || rhs->draw_dsc == NULL) {
+        if(lhs->draw_dsc == rhs->draw_dsc) return 0;
+        if(lhs->draw_dsc == NULL) return -1;
+        return 1;
+    }
+
     uint32_t lhs_dsc_size = lhs->draw_dsc->dsc_size;
     uint32_t rhs_dsc_size = rhs->draw_dsc->dsc_size;
 
-- 
2.43.0

