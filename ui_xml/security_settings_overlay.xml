<!-- Security Settings Overlay — PIN management and auto-lock configuration -->
<!-- lock_pin_set subject (0=no PIN, 1=PIN set) drives row visibility -->
<component>
  <view name="security_settings_overlay"
        extends="overlay_panel" width="#overlay_panel_width_full" title="Security" title_tag="Security"
        bg_color="#screen_bg">
    <!-- Content Area -->
    <lv_obj name="overlay_content" width="100%" flex_grow="1" style_pad_top="0" style_pad_left="#space_lg" style_pad_right="#space_lg" style_pad_bottom="#space_lg" scrollable="true" flex_flow="column">
      <!-- ================================================================== -->
      <!-- SET PIN — visible only when NO PIN is configured -->
      <!-- ================================================================== -->
      <lv_obj name="container_set_pin" width="100%" style_pad_all="0" scrollable="false">
        <bind_flag_if_not_eq subject="lock_pin_set" flag="hidden" ref_value="0"/>
        <setting_action_row name="row_set_pin"
                            label="Set PIN" label_tag="Set PIN" icon="lock"
                            description="Create a 4-6 digit security PIN"
                            description_tag="Create a 4-6 digit security PIN"
                            callback="on_set_pin_clicked"/>
      </lv_obj>
      <!-- ================================================================== -->
      <!-- CHANGE PIN — visible only when PIN IS configured -->
      <!-- ================================================================== -->
      <lv_obj name="container_change_pin" width="100%" style_pad_all="0" scrollable="false">
        <bind_flag_if_eq subject="lock_pin_set" flag="hidden" ref_value="0"/>
        <setting_action_row name="row_change_pin"
                            label="Change PIN" label_tag="Change PIN" icon="pencil"
                            description="Update your security PIN"
                            description_tag="Update your security PIN"
                            callback="on_change_pin_clicked"/>
      </lv_obj>
      <!-- ================================================================== -->
      <!-- REMOVE PIN — visible only when PIN IS configured -->
      <!-- ================================================================== -->
      <lv_obj name="container_remove_pin" width="100%" style_pad_all="0" scrollable="false">
        <bind_flag_if_eq subject="lock_pin_set" flag="hidden" ref_value="0"/>
        <setting_action_row name="row_remove_pin"
                            label="Remove PIN" label_tag="Remove PIN" icon="close_circle"
                            description="Disable the security PIN"
                            description_tag="Disable the security PIN"
                            callback="on_remove_pin_clicked"/>
      </lv_obj>
      <!-- ================================================================== -->
      <!-- AUTO-LOCK TOGGLE — visible only when PIN IS configured -->
      <!-- ================================================================== -->
      <lv_obj name="container_auto_lock" width="100%" style_pad_all="0" scrollable="false">
        <bind_flag_if_eq subject="lock_pin_set" flag="hidden" ref_value="0"/>
        <setting_toggle_row name="row_auto_lock"
                            label="Auto-lock" label_tag="Auto-lock" icon="clock"
                            description="Lock screen after idle timeout"
                            description_tag="Lock screen after idle timeout"
                            callback="on_auto_lock_changed"/>
      </lv_obj>
    </lv_obj>
  </view>
</component>
