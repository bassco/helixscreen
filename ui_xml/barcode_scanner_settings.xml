<!-- Barcode Scanner settings overlay. Persistent configuration for scanner -->
<!-- input-device selection and keyboard layout. Replaces ScannerPickerModal.-->
<component>
  <view name="barcode_scanner_settings"
        extends="overlay_panel" width="#overlay_panel_width_full"
        title="Barcode Scanner" title_tag="Barcode Scanner"
        bg_color="#screen_bg">
    <lv_obj name="overlay_content" width="100%" flex_grow="1"
            style_pad_top="0" style_pad_left="#space_lg" style_pad_right="#space_lg"
            style_pad_bottom="#space_lg" scrollable="true" flex_flow="column">

      <!-- Current Selection -->
      <setting_section_header title="CURRENT SELECTION" title_tag="CURRENT SELECTION"
                              icon="qrcode_scan"/>
      <lv_obj width="100%" height="content" flex_flow="row"
              style_flex_cross_place="center" style_pad_all="#space_md"
              style_pad_gap="#space_sm" style_bg_opa="0" style_border_width="0"
              scrollable="false">
        <text_body text="Selected" translation_tag="Selected" width="content"/>
        <text_muted name="current_device_label" bind_text="scanner_current_device_label"
                    flex_grow="1" style_text_align="right"/>
      </lv_obj>

      <!-- Keyboard Layout -->
      <setting_section_header title="KEYBOARD LAYOUT" title_tag="KEYBOARD LAYOUT"
                              icon="keyboard"/>
      <lv_obj width="100%" height="content" flex_flow="row"
              style_flex_cross_place="center" style_pad_left="#space_lg"
              style_pad_right="#space_lg" style_pad_top="#space_sm"
              style_pad_bottom="#space_sm" style_pad_gap="#space_sm"
              style_bg_opa="0" style_border_width="0" scrollable="false">
        <text_body text="Layout" translation_tag="Layout" flex_grow="1"/>
        <lv_dropdown name="keymap_dropdown" width="45%" height="content"
                     options="US QWERTY&#10;German QWERTZ&#10;French AZERTY"
                     bind_value="scanner_keymap_index"
                     style_radius="#border_radius" style_border_width="0">
          <event_cb trigger="value_changed" callback="on_bs_keymap_changed"/>
        </lv_dropdown>
      </lv_obj>

      <!-- USB Devices -->
      <setting_section_header title="USB DEVICES" title_tag="USB DEVICES" icon="usb"/>
      <lv_obj name="usb_device_list" width="100%" height="content" flex_flow="column"
              style_pad_all="0" style_pad_gap="0" style_bg_opa="0" style_border_width="0"
              scrollable="false"/>
      <lv_obj width="100%" height="content" flex_flow="row"
              style_flex_main_place="center" style_pad_all="#space_md"
              style_bg_opa="0" style_border_width="0" scrollable="false">
        <ui_button name="btn_refresh_usb" text="Refresh" translation_tag="Refresh"
                   icon="refresh" width="200">
          <event_cb trigger="clicked" callback="on_bs_refresh_usb"/>
        </ui_button>
      </lv_obj>

      <!-- Bluetooth (hidden when BT unavailable) -->
      <lv_obj name="section_bluetooth" width="100%" height="content" flex_flow="column"
              style_bg_opa="0" style_border_width="0" style_pad_all="0" scrollable="false">
        <bind_flag_if_eq subject="scanner_bt_available" flag="hidden" ref_value="0"/>
        <setting_section_header title="BLUETOOTH SCANNERS" title_tag="BLUETOOTH SCANNERS"
                                icon="bluetooth"/>
        <setting_dropdown_row name="row_bt_scanners"
                              label="Scanner" label_tag="Scanner"
                              icon="magnify"
                              dropdown_width="66%"
                              hide_description="true"
                              callback="on_bs_bt_scanner_selected"/>
        <lv_obj name="row_bt_actions" width="100%" height="content" flex_flow="row"
                style_flex_main_place="center" style_flex_cross_place="center"
                style_pad_all="#space_md" style_pad_gap="#space_md"
                style_bg_opa="0" style_border_width="0" scrollable="false">
          <spinner name="bt_scan_spinner" size="sm" hidden="true">
            <bind_flag_if_eq subject="scanner_bt_discovering" flag="hidden" ref_value="0"/>
          </spinner>
          <ui_button name="btn_bt_scan" text="Scan" translation_tag="Scan"
                     icon="magnify_scan" width="140">
            <event_cb trigger="clicked" callback="on_bs_scan_bluetooth"/>
          </ui_button>
          <ui_button name="btn_bt_pair" text="Pair" translation_tag="Pair"
                     icon="bluetooth" width="140" disabled="true">
            <event_cb trigger="clicked" callback="on_bs_bt_pair"/>
          </ui_button>
          <ui_button name="btn_bt_forget" text="Forget" translation_tag="Forget"
                     icon="delete" width="140" disabled="true">
            <event_cb trigger="clicked" callback="on_bs_bt_forget"/>
          </ui_button>
        </lv_obj>
      </lv_obj>

    </lv_obj>
  </view>
</component>
