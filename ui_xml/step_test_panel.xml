<component>
  <!-- Local Constants -->
  <consts>
    <!-- Step indicator circle size (responsive) -->
    <px name="step_indicator_small" value="16"/>
    <px name="step_indicator_medium" value="20"/>
    <px name="step_indicator_large" value="24"/>
    <!-- Step connector line thickness (responsive) -->
    <px name="step_connector_small" value="2"/>
    <px name="step_connector_medium" value="2"/>
    <px name="step_connector_large" value="3"/>
    <!-- Step label spacing from indicator (responsive) -->
    <px name="step_label_gap_small" value="6"/>
    <px name="step_label_gap_medium" value="8"/>
    <px name="step_label_gap_large" value="10"/>
    <!-- Step row gap for vertical layout (responsive) -->
    <px name="step_row_gap_small" value="8"/>
    <px name="step_row_gap_medium" value="12"/>
    <px name="step_row_gap_large" value="16"/>
    <!-- Step colors: omitted to use theme token defaults (primary, success, text_subtle, etc.) -->
    <!-- Override by adding step_pending_light/dark, step_active_light/dark, etc. consts -->
  </consts>
  <!-- Test panel for step progress widget demonstrations -->
  <view extends="lv_obj"
        width="100%" height="100%" style_pad_all="#space_lg" flex_flow="column" style_flex_main_place="start"
        style_flex_cross_place="center">
    <!-- Title -->
    <lv_label text="Step Progress Widget Test" translation_tag="Step Progress Widget Test" style_text_font="montserrat_20" style_pad_bottom="20"/>
    <!-- Vertical progress demo section -->
    <lv_obj name="vertical_section"
            width="90%" height="content" style_pad_all="#space_md" style_radius="#border_radius" flex_flow="column"
            style_flex_main_place="start" style_flex_cross_place="start">
      <text_body text="Vertical Progress (Retract Wizard)" translation_tag="Vertical Progress (Retract Wizard)" style_pad_bottom="#space_sm"/>
      <!-- Vertical progress widget container (created in C++) -->
      <lv_obj name="vertical_progress_container" width="100%" height="content" style_pad_all="0"
              style_bg_opa="0" style_border_width="0"/>
    </lv_obj>
    <!-- Horizontal progress demo section -->
    <lv_obj name="horizontal_section"
            width="100%" height="content" style_pad_all="#space_md" style_radius="#border_radius" style_pad_top="#space_md"
            flex_flow="column" style_flex_main_place="start" style_flex_cross_place="start">
      <text_body text="Horizontal Progress (Leveling Wizard)" translation_tag="Horizontal Progress (Leveling Wizard)" style_pad_bottom="#space_sm"/>
      <!-- Horizontal progress widget container (created in C++) -->
      <lv_obj name="horizontal_progress_container" width="100%" height="content" style_pad_all="0"
              style_bg_opa="0" style_border_width="0"/>
    </lv_obj>
    <!-- Control buttons -->
    <lv_obj name="button_row"
            width="90%" height="content" style_pad_top="20" style_pad_all="0" flex_flow="row"
            style_flex_main_place="space_evenly">
      <ui_button name="btn_prev" width="140" text="Previous" translation_tag="Previous">
        <event_cb trigger="clicked" callback="on_step_test_prev"/>
      </ui_button>
      <ui_button name="btn_next" width="140" text="Next" translation_tag="Next">
        <event_cb trigger="clicked" callback="on_step_test_next"/>
      </ui_button>
      <ui_button name="btn_complete" width="140" text="Complete" translation_tag="Complete" variant="success">
        <event_cb trigger="clicked" callback="on_step_test_complete"/>
      </ui_button>
    </lv_obj>
  </view>
</component>
