<!-- Single row in the barcode scanner device list (USB or Bluetooth). -->
<!-- Styling/layout entirely declarative; C++ instantiates one per device  -->
<!-- and attaches identifying data via lv_obj_set_user_data.               -->
<component>
  <api>
    <prop name="row_icon" type="string" default="usb"/>
    <prop name="row_label" type="string" default=""/>
    <prop name="row_sublabel" type="string" default=""/>
    <prop name="hide_forget" type="boolean" default="true"/>
    <prop name="hide_check" type="boolean" default="true"/>
  </api>
  <view name="barcode_scanner_device_row"
        extends="lv_obj" width="100%" height="content" flex_flow="row"
        style_flex_cross_place="center" style_pad_all="#space_md" style_pad_gap="#space_md"
        style_bg_opa="0" style_border_width="0" scrollable="false">
    <event_cb trigger="clicked" callback="on_bs_row_clicked"/>
    <icon src="$row_icon" size="md" variant="accent"/>
    <lv_obj width="0" flex_grow="1" flex_flow="column" style_pad_gap="#space_xs"
            style_bg_opa="0" style_border_width="0" style_pad_all="0" scrollable="false">
      <text_body text="$row_label" style_text_align="left"/>
      <text_small text="$row_sublabel" style_text_color="#text_muted" style_text_align="left"/>
    </lv_obj>
    <icon name="selected_check" src="check" size="md" variant="accent" hidden="$hide_check"/>
    <ui_button name="btn_forget" text="Forget" translation_tag="Forget" variant="secondary"
               width="100" hidden="$hide_forget">
      <event_cb trigger="clicked" callback="on_bs_row_forget"/>
    </ui_button>
  </view>
</component>
