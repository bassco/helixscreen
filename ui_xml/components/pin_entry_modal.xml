<!--
  PIN Entry Modal — numeric keypad for PIN set/change/remove flows.
  Similar layout to lock_screen.xml but inside a ui_dialog.
  Dots and heading are updated imperatively from C++ (PinEntryModal).
-->
<component>
  <consts>
    <!-- Dot indicator size — same as lock screen -->
    <px name="pin_dot_size" value="20"/>
    <!-- Keypad button height -->
    <px name="pin_btn_height" value="48"/>
  </consts>

  <styles>
    <!-- Filled dot: digit entered -->
    <style name="pin_dot_filled"
           bg_opa="255"
           bg_color="#primary_color"
           border_width="0"
           radius="99"/>
    <!-- Empty dot: digit not yet entered -->
    <style name="pin_dot_empty"
           bg_opa="0"
           border_width="2"
           border_color="#text_muted"
           border_opa="255"
           radius="99"/>
  </styles>

  <view name="pin_entry_modal"
        extends="lv_obj"
        width="340" height="content"
        align="center"
        style_bg_color="#card_bg" style_bg_opa="255"
        style_border_width="1"
        style_border_color="#text_muted"
        style_border_opa="64"
        style_radius="#border_radius"
        style_pad_all="0"
        flex_flow="column"
        style_flex_main_place="center"
        style_flex_cross_place="center"
        scrollable="false">

    <modal_header icon_src="lock" icon_variant="primary"
                  title="Enter PIN" title_tag="Enter PIN"/>

    <!-- Content: heading, dots, error, keypad -->
    <lv_obj width="100%" height="content"
            style_pad_all="#space_lg"
            style_pad_gap="#space_md"
            style_bg_opa="0"
            style_border_width="0"
            flex_flow="column"
            style_flex_main_place="center"
            style_flex_cross_place="center"
            scrollable="false">

      <!-- Dynamic heading text (updated from C++) -->
      <text_body name="pin_heading"
                 text="Enter New PIN"
                 style_text_align="center"
                 width="100%"/>

      <!-- 6 PIN dot indicators -->
      <lv_obj name="pin_dots_container"
              width="content" height="content"
              flex_flow="row"
              style_pad_gap="#space_sm"
              style_pad_all="0"
              style_bg_opa="0"
              style_border_width="0"
              align="center">
        <lv_obj name="pin_dot_0" width="#pin_dot_size" height="#pin_dot_size">
          <style name="pin_dot_empty"/>
        </lv_obj>
        <lv_obj name="pin_dot_1" width="#pin_dot_size" height="#pin_dot_size">
          <style name="pin_dot_empty"/>
        </lv_obj>
        <lv_obj name="pin_dot_2" width="#pin_dot_size" height="#pin_dot_size">
          <style name="pin_dot_empty"/>
        </lv_obj>
        <lv_obj name="pin_dot_3" width="#pin_dot_size" height="#pin_dot_size">
          <style name="pin_dot_empty"/>
        </lv_obj>
        <lv_obj name="pin_dot_4" width="#pin_dot_size" height="#pin_dot_size">
          <style name="pin_dot_empty"/>
        </lv_obj>
        <lv_obj name="pin_dot_5" width="#pin_dot_size" height="#pin_dot_size">
          <style name="pin_dot_empty"/>
        </lv_obj>
      </lv_obj>

      <!-- Error text (shown on PIN mismatch etc.) -->
      <text_small name="pin_error_label"
                  text=""
                  style_text_color="#error_color"
                  style_text_align="center"
                  width="100%"
                  hidden="true"/>

      <!-- 4x3 numeric keypad — mirrors lock_screen.xml layout -->
      <lv_obj name="pin_keypad"
              width="100%" height="content"
              flex_flow="row_wrap"
              style_flex_main_place="center"
              style_flex_track_place="center"
              style_pad_all="0"
              style_pad_gap="#space_sm"
              style_bg_opa="0"
              style_border_width="0"
              scrollable="false">

        <!-- Row 1: 1 2 3 -->
        <ui_button name="pin_digit_1"
                   width="30%" height="#pin_btn_height"
                   text="1" variant="secondary">
          <event_cb trigger="clicked" callback="pin_modal_digit_clicked"/>
        </ui_button>
        <ui_button name="pin_digit_2"
                   width="30%" height="#pin_btn_height"
                   text="2" variant="secondary">
          <event_cb trigger="clicked" callback="pin_modal_digit_clicked"/>
        </ui_button>
        <ui_button name="pin_digit_3"
                   width="30%" height="#pin_btn_height"
                   text="3" variant="secondary">
          <event_cb trigger="clicked" callback="pin_modal_digit_clicked"/>
        </ui_button>

        <!-- Row 2: 4 5 6 -->
        <ui_button name="pin_digit_4"
                   width="30%" height="#pin_btn_height"
                   text="4" variant="secondary">
          <event_cb trigger="clicked" callback="pin_modal_digit_clicked"/>
        </ui_button>
        <ui_button name="pin_digit_5"
                   width="30%" height="#pin_btn_height"
                   text="5" variant="secondary">
          <event_cb trigger="clicked" callback="pin_modal_digit_clicked"/>
        </ui_button>
        <ui_button name="pin_digit_6"
                   width="30%" height="#pin_btn_height"
                   text="6" variant="secondary">
          <event_cb trigger="clicked" callback="pin_modal_digit_clicked"/>
        </ui_button>

        <!-- Row 3: 7 8 9 -->
        <ui_button name="pin_digit_7"
                   width="30%" height="#pin_btn_height"
                   text="7" variant="secondary">
          <event_cb trigger="clicked" callback="pin_modal_digit_clicked"/>
        </ui_button>
        <ui_button name="pin_digit_8"
                   width="30%" height="#pin_btn_height"
                   text="8" variant="secondary">
          <event_cb trigger="clicked" callback="pin_modal_digit_clicked"/>
        </ui_button>
        <ui_button name="pin_digit_9"
                   width="30%" height="#pin_btn_height"
                   text="9" variant="secondary">
          <event_cb trigger="clicked" callback="pin_modal_digit_clicked"/>
        </ui_button>

        <!-- Row 4: backspace 0 confirm -->
        <ui_button name="pin_backspace"
                   width="30%" height="#pin_btn_height"
                   icon="backspace" text=""
                   variant="ghost">
          <event_cb trigger="clicked" callback="pin_modal_backspace_clicked"/>
        </ui_button>
        <ui_button name="pin_digit_0"
                   width="30%" height="#pin_btn_height"
                   text="0" variant="secondary">
          <event_cb trigger="clicked" callback="pin_modal_digit_clicked"/>
        </ui_button>
        <ui_button name="pin_confirm"
                   width="30%" height="#pin_btn_height"
                   icon="check" text=""
                   variant="primary">
          <event_cb trigger="clicked" callback="pin_modal_confirm_clicked"/>
        </ui_button>

      </lv_obj>
    </lv_obj>

    <!-- Cancel row -->
    <modal_button_row secondary_text="Cancel" secondary_tag="Cancel"
                      secondary_callback="pin_modal_cancel_clicked"/>
  </view>
</component>
