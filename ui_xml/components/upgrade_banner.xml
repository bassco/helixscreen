<component>
  <!--
    Persistent top-banner that prompts the user to upgrade when
    UpgradeNudge::should_show_banner() is true. Ships invisible: the C++
    side (UpgradeBanner singleton) attaches an instance to lv_layer_top
    during app init, then observes UpgradeNudge + UpdateChecker state and
    toggles visibility. Dismiss button persists per-version via
    UpgradeNudge::dismiss_current_version(); Update button navigates to
    Settings > About where the install can be triggered.

    Visual language mirrors toast_notification.xml: neutral elevated_bg
    surface with an info-colored icon accent. Keeps buttons readable and
    auto-contrasting without painting the whole bar a semantic color
    (which would hide variant="primary" CTAs against the same token).
  -->
  <view name="upgrade_banner" extends="lv_obj"
        width="100%" height="content"
        style_bg_color="#elevated_bg" style_bg_opa="255"
        style_border_width="#border_width" style_border_color="#border"
        style_border_side="bottom"
        style_pad_all="#space_sm" style_pad_gap="#space_sm"
        flex_flow="row"
        style_flex_main_place="space_between" style_flex_cross_place="center"
        scrollable="false" clickable="false">
    <!-- Left: icon + message, grows to fill remaining width -->
    <lv_obj width="1" height="content" flex_grow="1"
            style_pad_all="0" style_pad_gap="#space_sm"
            flex_flow="row" style_flex_cross_place="center"
            style_bg_opa="0" style_border_width="0"
            scrollable="false" clickable="false">
      <icon name="upgrade_banner_icon" src="arrow_up_circle" size="sm" variant="info"/>
      <text_body name="upgrade_banner_message" width="1" flex_grow="1"
                 bind_text="upgrade_banner_text" long_mode="dots"/>
    </lv_obj>
    <!-- Right: primary Update CTA + ghost dismiss (matches toast pattern) -->
    <ui_button name="upgrade_banner_update_btn"
               text="Update" translation_tag="Update" variant="primary">
      <event_cb trigger="clicked" callback="on_upgrade_banner_update"/>
    </ui_button>
    <ui_button name="upgrade_banner_dismiss_btn" icon="xmark" variant="ghost">
      <event_cb trigger="clicked" callback="on_upgrade_banner_dismiss"/>
    </ui_button>
  </view>
</component>
