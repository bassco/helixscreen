<component>
  <view name="panel_widget_lock" extends="lv_obj"
        height="100%" flex_grow="1" style_pad_all="0" scrollable="false">
    <ui_button name="lock_button"
               width="100%" height="100%" variant="ghost" style_border_width="0" focusable="false">
      <!-- Closed lock — visible when PIN is set -->
      <icon name="lock_icon_closed" src="lock" size="#icon_size" align="center" variant="secondary">
        <bind_flag_if_eq subject="lock_pin_set" flag="hidden" ref_value="0"/>
      </icon>
      <!-- Open lock — visible when NO PIN is set -->
      <icon name="lock_icon_open" src="lock_open" size="#icon_size" align="center" variant="muted">
        <bind_flag_if_not_eq subject="lock_pin_set" flag="hidden" ref_value="0"/>
      </icon>
      <event_cb trigger="clicked" callback="lock_screen_clicked_cb"/>
    </ui_button>
  </view>
</component>
