<component name="tool_picker_button">
    <api>
        <prop name="tool_text" type="string" default="T0"/>
    </api>
    <view extends="lv_obj" name="tool_picker_btn_root"
          width="100%" height="content"
          style_pad_all="0" style_bg_opa="0" style_border_width="0" scrollable="false">
        <ui_button name="tool_btn" variant="ghost" width="100%" height="content"
                   style_min_height="#button_height_sm">
            <text_small name="tool_btn_label" text="$tool_text" align="center"/>
        </ui_button>
    </view>
</component>
