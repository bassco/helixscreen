<!-- Eddy current probe type-specific control panel (BTT Eddy, Mellow Fly Eddy, etc.) -->
<component>
  <view name="probe_eddy_panel"
        extends="lv_obj" width="100%" height="content" style_pad_all="0"
        flex_flow="column" style_pad_gap="#space_sm" scrollable="false">

    <setting_section_header title="EDDY CURRENT" title_tag="EDDY CURRENT" icon="sine_wave"/>

    <!-- Action buttons — 2 equal-width -->
    <lv_obj width="100%" height="content" style_pad_all="0" flex_flow="row"
            style_pad_gap="#space_sm" scrollable="false">
      <ui_button name="btn_eddy_calibrate"
                 width="1" flex_grow="1" height="#button_height_sm" variant="secondary" text="Calibrate" translation_tag="Calibrate"
                 icon="target">
        <event_cb trigger="clicked" callback="on_eddy_calibrate"/>
      </ui_button>
      <ui_button name="btn_eddy_drive_current"
                 width="1" flex_grow="1" height="#button_height_sm" variant="secondary" text="Drive Cal" translation_tag="Drive Cal"
                 icon="tune">
        <event_cb trigger="clicked" callback="on_eddy_drive_current"/>
      </ui_button>
    </lv_obj>
  </view>
</component>
