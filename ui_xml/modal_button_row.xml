<?xml version="1.0"?>
<component>
  <api>
    <prop name="primary_text" type="string" default="OK"/>
    <prop name="secondary_text" type="string" default="Cancel"/>
    <prop name="primary_tag" type="string" default=""/>
    <prop name="secondary_tag" type="string" default=""/>
    <prop name="primary_callback" type="string"/>
    <prop name="secondary_callback" type="string"/>
    <prop name="primary_icon" type="string" default=""/>
    <prop name="secondary_icon" type="string" default=""/>
    <prop name="primary_variant" type="string" default="primary"/>
    <prop name="show_secondary" type="string" default="true"/>
  </api>
  <view extends="lv_obj" width="100%" height="content" style_pad_all="0" style_pad_gap="0" flex_flow="column">
    <!-- Horizontal divider -->
    <divider_horizontal/>
    <!-- Button row -->
    <lv_obj width="100%" height="#button_height" style_pad_all="0" style_pad_gap="0" flex_flow="row">
      <!-- Secondary button. style_border_width="0" so the theme's 1px button
           border doesn't stack against divider_vertical (previously looked
           like a triple-thick edge between Cancel and Save). -->
      <ui_button name="btn_secondary" height="100%" flex_grow="1" style_radius="0" style_border_width="0" focusable="false" icon="$secondary_icon" text="$secondary_text" translation_tag="$secondary_tag">
        <event_cb trigger="clicked" callback="$secondary_callback"/>
      </ui_button>
      <!-- Vertical divider -->
      <divider_vertical/>
      <!-- Primary button (same border-width suppression as secondary).
           variant="primary" by default; pass primary_variant="danger" for
           destructive actions (Shutdown, Cancel Print, etc.). -->
      <ui_button name="btn_primary" variant="$primary_variant" height="100%" flex_grow="1" style_radius="0" style_border_width="0" focusable="false" icon="$primary_icon" text="$primary_text" translation_tag="$primary_tag">
        <event_cb trigger="clicked" callback="$primary_callback"/>
      </ui_button>
    </lv_obj>
  </view>
</component>
