<component>
  <api>
    <prop name="message" type="string"/>
    <!-- Icon appearance driven per-instance so multiple stacked toasts of
         different severities can coexist without shared subjects. -->
    <prop name="icon_glyph" type="string" default="󰋼"/>
    <prop name="icon_color" type="string" default="#info"/>
    <!-- Action button is hidden by default; set hide_action="false" to show it.
         action_text / wiring of the click callback is done in C++ after create. -->
    <prop name="action_text" type="string" default=""/>
    <prop name="hide_action" type="string" default="true"/>
  </api>
  <!-- Toast card - floating appearance with shadow. Width comes from the parent
       stack container (sized in C++ based on screen width); height tight to
       content. Positioning of the stack itself is handled by ToastManager on
       lv_layer_top. -->
  <view name="toast_root"
        extends="lv_obj" width="100%" height="content"
        style_radius="#border_radius" style_pad_all="#space_lg"
        style_pad_gap="#space_sm" style_border_width="0" style_bg_color="#screen_bg" style_bg_opa="255"
        style_shadow_width="#space_2xl" style_shadow_spread="#space_xs" style_shadow_opa="120"
        style_shadow_ofs_y="#space_xs" flex_flow="row" style_flex_main_place="start"
        style_flex_cross_place="center">
    <lv_label name="icon"
              text="$icon_glyph" style_text_font="mdi_icons_24" style_text_color="$icon_color"/>
    <text_body name="toast_message"
               text="$message" flex_grow="1" long_mode="wrap" style_pad_left="#space_sm" style_pad_right="#space_sm"/>
    <ui_button name="toast_action_btn"
               width="content" height="36" text="$action_text" variant="success" style_min_width="72"
               hidden="$hide_action"/>
    <ui_button name="toast_close_btn" width="40" height="40" icon="xmark" variant="ghost">
      <event_cb trigger="clicked" callback="toast_close_btn_clicked"/>
    </ui_button>
  </view>
</component>
